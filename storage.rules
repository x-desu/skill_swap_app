rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── User Profile Photos ──────────────────────────────────────────────────
    // Any signed-in user can read profile photos (needed for discovery/chat/matches).
    // Only the owner can write their own avatar.
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ─── Chat Images ─────────────────────────────────────────────────────────
    // Only participants of the match can read or write chat images.
    match /chat-images/{matchId}/{imageId} {
      allow read: if request.auth != null &&
        request.auth.uid in firestore.get(/databases/(default)/documents/matches/$(matchId)).data.users;

      allow write: if request.auth != null &&
        request.auth.uid in firestore.get(/databases/(default)/documents/matches/$(matchId)).data.users;
    }

  }
}
