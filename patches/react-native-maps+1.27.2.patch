+- (AIRMapMarker*) markerForCallout:(AIRMapCallout*)callout {
+    AIRMapMarker* marker = nil;
+    NSArray* markers = [self markers];
+    for (AIRMapMarker* mrk in markers) {
+        if (mrk.calloutView == callout) {
+            marker = mrk;
+            break;
+        }
+    }
+    return marker;
+}
