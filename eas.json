{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "RAZORPAY_KEY_ID": "${secrets.RAZORPAY_KEY_ID}",
         "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "EAS_BUILD_NPM_CI": "0"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "RAZORPAY_KEY_ID": "${secrets.RAZORPAY_KEY_ID}",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}