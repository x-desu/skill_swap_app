{
  "expo": {
    "name": "SkillSwap",
    "slug": "skill_swap_app",
    "scheme": "skillswap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/skillswap-icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/skillswap-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skillswap.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SkillSwap needs access to your location to automatically determine your city and country."
      }
    },
    "android": {
      "package": "com.skillswap.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/skillswap-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/skillswap-icon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.491963117666-tuavrle0t2ut5ltb7moq77iqjcr438rp"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "SkillSwap needs access to your photos to set a profile picture.",
          "cameraPermission": "SkillSwap needs camera access to take a profile photo."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SkillSwap needs access to your location to automatically determine your city and country."
        }
      ]
    ]
  }
}
