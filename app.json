{
  "expo": {
    "name": "SkillSwap",
    "slug": "skill_swap_app",
    "scheme": "skillswap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/skillswap-icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/skillswap-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skillswap.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SkillSwap needs access to your location to automatically determine your city and country."
      },
      "bitcode": false
    },
    "android": {
      "package": "com.skillswap.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/skillswap-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.WAKE_LOCK",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "web": {
      "favicon": "./assets/skillswap-icon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.491963117666-tuavrle0t2ut5ltb7moq77iqjcr438rp"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAuth",
              "RNFBFirestore",
              "RNFBStorage"
            ]
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "SkillSwap needs access to your photos to set a profile picture.",
          "cameraPermission": "SkillSwap needs camera access to take a profile photo."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SkillSwap needs access to your location to automatically determine your city and country."
        }
      ],
      "expo-localization",
      "@stream-io/video-react-native-sdk",
      "@config-plugins/react-native-webrtc"
    ],
    "extra": {
      "razorpayKeyId": "rzp_live_SX039qZ9OOIngV",
      "router": {},
      "eas": {
        "projectId": "6842636a-67df-4aed-8533-8e686f247a15"
      }
    },
    "owner": "desudesai"
  }
}
