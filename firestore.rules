rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isSwapParticipant(swapData) {
      return isSignedIn() && (
        request.auth.uid == swapData.fromUid ||
        request.auth.uid == swapData.toUid
      );
    }

    function userServerOnlyKeys() {
      return [
        'credits',
        'subscriptionTier',
        'subscriptionStatus',
        'subscriptionProductId',
        'subscriptionExpiresAt',
        'hasPremiumAccess',
        'revenueCatAppUserId'
      ];
    }

    function userTouchedServerOnlyOnCreate(data) {
      return data.keys().hasAny(userServerOnlyKeys());
    }

    function userTouchedServerOnlyOnUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(userServerOnlyKeys());
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) && !userTouchedServerOnlyOnCreate(request.resource.data);
      allow update: if isOwner(uid) && !userTouchedServerOnlyOnUpdate();

      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(uid);
        allow create: if isSignedIn();
      }
    }

    match /skills/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /likes/{id} {
      // Allow list queries where user queries their own likes
      allow list: if isSignedIn() && request.query.limit <= 100;
      // Allow read individual documents where user is participant
      allow get: if isSignedIn() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.fromUid;
    }

    match /matches/{id} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;
      allow create: if false;
      allow update: if isSignedIn() && request.auth.uid in resource.data.users;

      match /messages/{messageId} {
        allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/matches/$(id)).data.users;
      }
    }

    match /notifications/{id} {
      allow read, update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if false;
    }

    match /creditLedger/{ledgerId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /subscriptions/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /purchaseEvents/{eventId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
