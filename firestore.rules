rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isSwapParticipant(swapData) {
      return isSignedIn() && (
        request.auth.uid == swapData.fromUid ||
        request.auth.uid == swapData.toUid
      );
    }

    // ─── users/{uid} ─────────────────────────────────────────────────────────
    // Any signed-in user can READ (needed for discovery feed).
    // Only the owner can WRITE their own document (create or update).
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) && 
        (!request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['credits', 'creditsSpent', 'lastPaymentId', 'isPremium', 'premiumExpiresAt']));
    }

    // ─── swapRequests/{id} ───────────────────────────────────────────────────
    match /swapRequests/{id} {
      allow read: if isSwapParticipant(resource.data);

      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.status == 'pending';

      allow update: if isSwapParticipant(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'updatedAt']);

      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.fromUid
        && resource.data.status == 'pending';
    }

    // ─── skills/{id} ─────────────────────────────────────────────────────────
    match /skills/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ─── notifications/{uid}/items/{id} (legacy nested shape) ───────────────
    match /notifications/{uid}/items/{id} {
      allow read, write: if isOwner(uid);
    }

    // ─── notifications/{id} (current top-level shape used by the app) ───────
    match /notifications/{id} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // ─── likes/{id} ──────────────────────────────────────────────────────────
    match /likes/{id} {
      // User can read likes they sent or received
      allow read: if isSignedIn() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      // User can create a like if they are the sender
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.fromUid;
    }

    // ─── matches/{id} ────────────────────────────────────────────────────────
    match /matches/{id} {
      // User can read matches they are a part of
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;
      // Anyone can create a match (Server/Client creation) as long as they are one of the users
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.users;
      // Allow update for lastMessage
      allow update: if isSignedIn() && request.auth.uid in resource.data.users;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/matches/$(id)).data.users;
      }
    }

    // ─── calls/{id} ──────────────────────────────────────────────────────────
    // Call documents are server-managed. Clients can only read if they
    // participate in the chat/video session.
    match /calls/{id} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.callerUid ||
        request.auth.uid == resource.data.calleeUid
      );
      allow write: if false;
    }

    // ─── Deny all other paths ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
